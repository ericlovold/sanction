# Sanction environment — copy to .env.local (dev) / set in Vercel (prod).
# Never commit real values.

# --- Core ---
DATABASE_URL=                       # Neon Postgres connection string
SANCTION_SIGNING_SECRET=            # JWT signing key (base64)
SANCTION_CREDENTIAL_ENCRYPTION_KEY= # AES-256 master (base64) — legacy/local-wrap root
SANCTION_WALLET_ID=                 # demo wallet id for the public read-only dashboard

# --- SEC-1 envelope encryption (prod root of trust; optional in dev) ---
SANCTION_KMS_KEY_ARN=               # unset => local-wrap fallback (no AWS needed)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Better Auth (human sign-in: Google + GitHub) ---
BETTER_AUTH_SECRET=                 # openssl rand -base64 32
BETTER_AUTH_URL=https://getsanction.com          # prod origin (http://localhost:3000 in dev)
NEXT_PUBLIC_BETTER_AUTH_URL=https://getsanction.com  # same value, exposed to the client

# Google: console.cloud.google.com → OAuth client (Web)
# Authorized redirect: https://getsanction.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub: github.com/settings/developers → OAuth App (scope: user:email)
# Callback URL: https://getsanction.com/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional — authorizes Vercel Cron calls to /api/cron/* (weekly digests).
# Vercel sends it automatically as `Authorization: Bearer <value>` once set.
# Unset ⇒ cron endpoints fail closed (401), digests simply don't run.
CRON_SECRET=

# Optional — pins the origin advertised in AuthZEN discovery metadata and AARP
# access_request offers. Leave unset on Vercel (the platform validates Host,
# so the request origin is trusted and previews self-describe correctly); set
# it when serving behind a proxy whose Host header you don't control.
SANCTION_PUBLIC_ORIGIN=
