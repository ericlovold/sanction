generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Fixed-window rate-limit counter, keyed by "<bucket>:<ip>". Approximate (good
// enough to stop mass abuse without Redis); rows reset per window.
model RateLimit {
  key       String   @id
  count     Int      @default(0)
  windowEnd DateTime

  @@index([windowEnd])
}

model Wallet {
  id         String   @id @default(cuid())
  name       String
  ownerEmail String   @unique
  createdAt  DateTime @default(now())

  // Account tree (additive): a wallet may nest under a parent wallet, forming an
  // org → tenant → sub-tenant hierarchy. Null = root (every existing wallet).
  // Subtree reporting rolls spend up; /authorize enforces opt-in subtree caps.
  parentId String?
  parent   Wallet?  @relation("WalletTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Wallet[] @relation("WalletTree")

  // Owner management key (sk_ prefix), shown once at creation. Gates the
  // management plane (create agents, manage vault/policy, read stats).
  // Nullable for wallets created before auth was introduced — those fail
  // closed until bootstrapped via /wallets/bootstrap-key.
  mgmtKeyHash   String? @unique
  mgmtKeyPrefix String?

  // Human identity (Better Auth). A wallet gets owned by a User the first time
  // that user signs in with Google/GitHub; null for legacy/magic-link wallets,
  // which still authenticate via the management key. Additive — the session
  // bridge (lib/session.ts) claims a wallet by email on first social login.
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Acquisition attribution (additive): first-touch channel captured at signup,
  // so the funnel can tie source channel → wallet → first governed decision.
  // Written once at creation from the acquisition cookie (lib/acquisition.ts);
  // analytics-grade, never authoritative for anything.
  acqSource   String? // utm_source or ?src= (e.g. "mcp", "docs", "hn")
  acqMedium   String? // utm_medium
  acqCampaign String? // utm_campaign
  acqReferrer String? // referrer host at first touch
  acqLanding  String? // first path seen (e.g. "/docs/bedrock")

  // Kill-switch: a frozen wallet (or any frozen ancestor) denies every data-plane
  // action — spend, tool, provision, capability, exec, tokens, gateway — with
  // WALLET_FROZEN until unfrozen. Freezing is the owner's one-control stop; it
  // never deletes state, so unfreezing resumes exactly where the fleet stopped.
  frozenAt     DateTime?
  frozenReason String?

  agents           Agent[]
  policy           Policy?
  credentials      CredentialVault[]
  clearances       AgentClearance[]
  executionTokens  ExecutionToken[]
  webhooks         Webhook[]
  magicLinks       MagicLink[]
  budgetCounters   WalletBudgetCounter[]
  pendingApprovals PendingApproval[]
  grants           Grant[]
  outcomes         OutcomeEvent[]
  reallocationsFrom BudgetReallocation[] @relation("ReallocFrom")
  reallocationsTo   BudgetReallocation[] @relation("ReallocTo")

  @@index([parentId])
  @@index([userId])
  @@index([acqSource])
}

// A business result the wallet's spend is accountable to — an enrollment, a
// booked visit, a signed engagement. Reported by the operator's own systems
// (webhook/API/MCP); Sanction never invents outcomes. Spend ÷ outcomes over a
// window is the cost-per-outcome the Policy ceiling governs: the difference
// between "capped spend" and "spend accountable to a result" (CAC, CPA, …).
model OutcomeEvent {
  id         String   @id @default(cuid())
  walletId   String
  agentId    String?  // optional: the agent whose play produced it, when known
  kind       String   // operator vocabulary: "enrollment", "booking", ...
  valueUsd   Float?   // optional value of the outcome (LTV math stays upstream)
  playLabel  String?  // optional campaign/play tag for reporting
  dedupeKey  String?  // client-supplied; makes reporting idempotent per wallet
  metadataJson Json?
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, dedupeKey])
  @@index([walletId, kind, occurredAt])
}

// One budget move between two sibling pools — the audit answer to "who moved
// the money, when, and why". The cap changes themselves also land as
// PolicyRevision snapshots; this row ties the pair together as a single event.
model BudgetReallocation {
  id           String   @id @default(cuid())
  fromWalletId String
  toWalletId   String
  amountCents  Int
  budget       String   @default("subtree_daily_cap") // which cap moved
  reason       String?
  actor        String   // "api" | "dashboard"
  createdAt    DateTime @default(now())

  fromWallet Wallet @relation("ReallocFrom", fields: [fromWalletId], references: [id], onDelete: Cascade)
  toWallet   Wallet @relation("ReallocTo", fields: [toWalletId], references: [id], onDelete: Cascade)

  @@index([fromWalletId, createdAt])
  @@index([toWalletId, createdAt])
}

// ── Better Auth (human identity) ────────────────────────────────────────────
// These four models are Better Auth's core schema (betterAuth() in lib/auth-config.ts).
// Field names/types match its contract exactly — do not rename. Sign-in methods
// (Google, GitHub) write here; a User then owns one or more Wallets above.
model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions Session[]
  accounts Account[]
  wallets  Wallet[]

  @@map("user")
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// One-time email sign-in / recovery token. The raw token is emailed; only its
// sha256 hash is stored. Single-use (usedAt) + short TTL (expiresAt). Verifying
// a link rotates the wallet's management key, so losing the key is recoverable
// without ever storing it in the clear.
model MagicLink {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  walletId  String
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  wallet    Wallet    @relation(fields: [walletId], references: [id])

  @@index([walletId])
}

// Owner-registered HTTP endpoint notified on events (escalations, budget trips).
// The owner verifies delivery with an HMAC-SHA256 signature over the body.
model Webhook {
  id        String   @id @default(cuid())
  walletId  String
  url       String
  secret    String
  events    String[] @default(["approval.created", "approval.resolved", "escalation.created", "escalation.resolved"])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
}

model Agent {
  id           String   @id @default(cuid())
  walletId     String
  name         String
  apiKeyHash   String   @unique
  apiKeyPrefix String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  // Best-effort "last used" for the console; stamped (throttled) on each
  // authenticated agent call. Null = never used since this column landed.
  lastUsedAt   DateTime?

  // Seat semantics: an agent is a seat you can hand to whoever holds it.
  // holder = the current human (display/audit only, never auth-bearing).
  // expiresAt = contractor auto-shutoff; past this instant the key fails
  // closed on every plane (data plane and gateway). Null = no expiry.
  holder    String?
  expiresAt DateTime?

  // Per-agent budget overrides (cents). Null = inherit the wallet policy.
  dailyTokenBudgetUsd  Int?
  dailySpendBudgetUsd  Int?
  perTransactionMaxUsd Int?
  escalateOverUsd      Int?

  wallet          Wallet                 @relation(fields: [walletId], references: [id])
  tokenLogs       TokenLog[]
  authRequests    AuthorizationRequest[]
  clearance       AgentClearance?
  executionTokens ExecutionToken[]
  pendingApprovals PendingApproval[]
  grants           Grant[]

  @@index([walletId])
}

model Policy {
  id       String @id @default(cuid())
  walletId String @unique

  // All values in cents. The spend ladder (enforced in /authorize) reads:
  //   amount <= autoApproveUnderUsd            -> approved (silent)
  //   autoApproveUnderUsd < amount <= escalateOverUsd -> approved
  //   escalateOverUsd < amount <= perTransactionMaxUsd -> escalated (human)
  //   amount > perTransactionMaxUsd            -> denied (hard cap)
  // For escalation to be reachable, keep escalateOverUsd < perTransactionMaxUsd.
  dailyTokenBudgetUsd  Int @default(1000)  // $10
  dailySpendBudgetUsd  Int @default(5000)  // $50
  monthlySpendBudgetUsd Int?               // optional monthly spend cap; null = no monthly limit
  subtreeDailyCapUsd   Int?                // optional subtree cap; null = no tree-wide cap
  perTransactionMaxUsd Int @default(5000)  // $50  — hard cap (deny over)
  autoApproveUnderUsd  Int @default(1000)  // $10  — silent auto-approve floor
  escalateOverUsd      Int @default(2500)  // $25  — escalate above this (must be < perTransactionMaxUsd)

  allowedCategories String[] @default(["software", "services", "research", "infrastructure"])
  blockedCategories String[] @default(["gambling", "adult", "crypto"])

  // Tool governance (ADR-0009 M3): authorize any MCP tool invocation the same way
  // spend is authorized. Empty allowedTools = allow all (governance is opt-in for
  // tools). A tool in escalateTools returns "escalated" (human approval).
  allowedTools  String[] @default([])
  blockedTools  String[] @default([])
  escalateTools String[] @default([])

  // Provision governance: authorize resource allocation (seats, licenses,
  // infrastructure) the same way. Empty allowedResources = allow all (opt-in,
  // like tools). A resource in escalateResources always requires human approval,
  // regardless of amount.
  allowedResources  String[] @default([])
  blockedResources  String[] @default([])
  escalateResources String[] @default([])

  // Capability governance (CAP-1): one ordered rule list for every kind of
  // new capability an agent can acquire or exercise — skills, plugins, APIs,
  // installs. Entries are { pattern, effect: block|allow|escalate } with
  // namespaced ids (skill:install:*, plugin:*, api:github.com/*) and
  // prefix-glob matching. Empty = allow all (governance is opt-in, like tools).
  capabilityRules Json @default("[]")

  // Cost-per-outcome ceiling (CPO-1): governs spend ÷ outcomes (CAC/CPA-class
  // metrics), not just absolute spend. When the wallet's windowed cost per
  // `outcomeKind` outcome would cross the ceiling, further spend ESCALATES —
  // the channel auto-throttles to human-gated, it is never silently cut off.
  // Deliberate: the throttle gates even sub-floor charges (a throttled channel
  // has no silent lane). Null ceiling = off. minOutcomes guards cold starts.
  outcomeKind               String? // which outcome the ceiling watches, e.g. "enrollment"
  costPerOutcomeCeilingUsd  Int?    // cents; null = no ceiling
  costPerOutcomeWindowDays  Int @default(30)
  costPerOutcomeMinOutcomes Int @default(5)

  // Escalation deadlock guard (UX-2): an escalated request that no human resolves
  // within escalationTimeoutMins is settled to the fallback terminal state on the
  // next read. 0 = wait indefinitely. Default action is fail-closed (deny).
  escalationTimeoutMins   Int    @default(60)
  escalationTimeoutAction String @default("deny") // deny | approve

  // Evidence (EVID-1): every mutation bumps currentRevision and writes an
  // immutable PolicyRevision snapshot; decisions record the revision they ran
  // under, so "what policy was in force?" stays answerable after any edit.
  currentRevision Int @default(1)

  updatedAt DateTime @updatedAt
  wallet    Wallet   @relation(fields: [walletId], references: [id])
  revisions PolicyRevision[]
}

// Append-only history of policy states (EVID-1). Never updated, never deleted
// while the policy lives — the evidentiary record replay resolves against.
model PolicyRevision {
  id           String   @id @default(cuid())
  policyId     String
  walletId     String
  revision     Int
  snapshotJson Json     // full policy fields in cents at this revision
  createdAt    DateTime @default(now())

  policy Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([policyId, revision])
  @@index([walletId, createdAt])
}

model TokenLog {
  id        String   @id @default(cuid())
  agentId   String
  model     String
  tokensIn  Int
  tokensOut Int
  costUsd   Float
  taskLabel String?
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id])

  @@index([agentId, createdAt])
}

// Encrypted credential stored in vault — raw value never exposed directly
model CredentialVault {
  id            String    @id @default(cuid())
  walletId      String
  label         String
  type          String    // api_key | oauth_token | certificate | license | password
  encryptedValue String
  // SEC-1 envelope encryption: id of the WalletKey whose wrapped DEK encrypts
  // this credential (ciphertext V3). Null for pre-V3 blobs (V2/V1/V0), which
  // decrypt via the synchronous fallthrough in lib/jwt.ts.
  keyId         String?
  allowedAgentIds String[] @default([]) // empty = all agents in wallet
  scopes        String[]  @default([])  // what this credential grants
  minClearance  Int       @default(1)   // 1-5; agent clearance must be >= this to access
  expiresAt     DateTime?
  // Soft-retire: a revoked credential can no longer be injected, but its
  // injection audit history is preserved (we never hard-delete the trail).
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  wallet        Wallet          @relation(fields: [walletId], references: [id])
  injections    CredentialInjection[]

  @@index([walletId])
}

// SEC-1 envelope encryption: per-wallet data-encryption key (DEK), stored
// wrapped — never in plaintext. In production the DEK is wrapped by an AWS KMS
// key (keyRef = the key ARN) so unwrapping requires a live, audited KMS call; in
// local/CI/preview (no SANCTION_KMS_KEY_ARN) it's wrapped by the env master and
// keyRef = "local". One key per wallet in Phase 1 (walletId unique); rotation in
// Phase 2 relaxes this and adds versioning.
model WalletKey {
  id         String    @id @default(cuid())
  walletId   String
  wrappedDek String    // base64 of the KMS-wrapped (or env-master-wrapped) DEK
  keyRef     String    // KMS key ARN, or "local" for the env-master fallback
  isActive   Boolean   @default(true) // exactly one active per wallet (partial unique index in SQL)
  retiredAt  DateTime? // set when rotated out; row kept so old blobs stay decryptable
  createdAt  DateTime  @default(now())

  @@index([walletId])
}

// Clearance level assigned to a specific agent
model AgentClearance {
  id          String    @id @default(cuid())
  walletId    String
  agentId     String
  level       Int       @default(1) // 1-5
  industry    String    @default("general") // general | healthcare | legal | financial | enterprise
  grantedAt   DateTime  @default(now())
  expiresAt   DateTime?
  restrictions Json?    // additional constraints at this clearance level

  wallet Wallet @relation(fields: [walletId], references: [id])
  agent  Agent  @relation(fields: [agentId], references: [id])

  @@unique([walletId, agentId])
  @@unique([agentId])
  @@index([agentId])
}

// Short-lived JWT issued per execution — bounded scope, 15min TTL
model ExecutionToken {
  id          String    @id // = jti (JWT ID, unique per issuance)
  agentId     String
  walletId    String
  scope       String[]  // which credential labels this token can inject
  budgetUsd   Float     // spend authority for this execution
  spentUsd    Float     @default(0)
  clearance   Int       @default(1)
  issuedAt    DateTime  @default(now())
  expiresAt   DateTime
  revokedAt   DateTime?
  containerId String?   // set when a docker container claims this token
  status      String    @default("active") // active | expired | revoked | completed

  agent  Agent  @relation(fields: [agentId], references: [id])
  wallet Wallet @relation(fields: [walletId], references: [id])
  injections CredentialInjection[]

  @@index([agentId])
  @@index([status, expiresAt])
}

// Audit record of every credential injection — what was accessed, when, by whom
model CredentialInjection {
  id               String   @id @default(cuid())
  executionTokenId String
  credentialId     String
  injectedAt       DateTime @default(now())

  executionToken ExecutionToken  @relation(fields: [executionTokenId], references: [id])
  credential     CredentialVault @relation(fields: [credentialId], references: [id])

  @@index([executionTokenId])
}

model AuthorizationRequest {
  id             String    @id @default(cuid())
  agentId        String
  kind           String    @default("spend") // spend | provision | tool
  action         String    // spend: purchase | subscribe | transfer · provision: allocate · tool: invoke
  amountUsd      Float
  merchant       String    // provision rows store the resource here (shared display/audit column)
  category       String
  detailsJson    Json?     // provision: { resource, line_item, quantity, unit_price_usd }
  description    String?
  status         String    @default("pending") // pending | approved | denied | escalated
  decidedAt      DateTime?
  decisionNote   String?
  // Evidence (EVID-1): the policy revision this decision ran under, and the
  // exact engine context it evaluated — enough to replay the pure ladder and
  // reproduce the decision (determinism principle, docs/DOMAIN.md).
  policyRevision      Int?
  decisionContextJson Json?
  idempotencyKey String?   // client-supplied; dedupes retries per agent
  createdAt      DateTime  @default(now())

  agent Agent @relation(fields: [agentId], references: [id])

  @@unique([agentId, idempotencyKey])
  @@index([agentId, createdAt])
  @@index([status])
}

// Generic human approval request. Spend, tool, credential, and future governed
// actions all land here when a decision escalates to a person.
model PendingApproval {
  id              String    @id @default(cuid())
  walletId        String
  agentId         String
  actionType      String
  status          String    @default("pending") // pending | approved | denied | expired
  subjectJson     Json
  resourceJson    Json
  constraintsJson Json?
  reason          String?
  code            String?
  sourceType      String?
  sourceId        String?
  expiresAt       DateTime?
  resolvedAt      DateTime?
  resolvedBy      String?
  resolutionNote  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  agent  Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  grants Grant[] @relation("GrantFromApproval")

  @@unique([sourceType, sourceId])
  @@index([walletId, status, createdAt])
  @@index([agentId, createdAt])
  @@index([actionType, status])
}

// Ephemeral authority issued from a human approval. A grant is the audit answer
// to "who authorized this agent to do this, under what constraints?"
model Grant {
  id                   String    @id @default(cuid())
  walletId             String
  agentId              String
  actionType           String
  status               String    @default("active") // active | consumed | expired | revoked
  subjectJson          Json
  resourceJson         Json
  constraintsJson      Json?
  sourceType           String?
  sourceId             String?
  issuedBy             String?
  issuedFromApprovalId String?
  justification        String?
  expiresAt            DateTime?
  consumedAt           DateTime?
  revokedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  wallet             Wallet           @relation(fields: [walletId], references: [id], onDelete: Cascade)
  agent              Agent            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  issuedFromApproval PendingApproval? @relation("GrantFromApproval", fields: [issuedFromApprovalId], references: [id], onDelete: SetNull)

  @@index([walletId, status, createdAt])
  @@index([agentId, createdAt])
  @@index([actionType, status])
  @@index([issuedFromApprovalId])
  @@index([sourceType, sourceId])
}

// Running counters for opt-in subtree caps. /authorize updates these atomically
// across capped ancestors so sibling agents cannot race past a parent cap.
model WalletBudgetCounter {
  id          String   @id @default(cuid())
  walletId    String
  period      String
  periodStart DateTime
  spentCents  Int      @default(0)
  updatedAt   DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([walletId, period, periodStart])
  @@index([period, periodStart])
}

// Awareness-stage marketing lead — captured before signup, owned in our DB so we
// can message the list ourselves. Unique email = idempotent capture.
model Lead {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?  // where it was captured: landing, hn, etc.
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Public, build-in-public feature request. Submitted by users on /roadmap, then
// curated: only isPublished ideas show on the board. status drives the column it
// appears in and ties the board to the published roadmap. authorEmail is captured
// for follow-up (also mirrored into Lead) but never rendered publicly.
model Idea {
  id          String   @id @default(cuid())
  title       String
  detail      String?
  category    String?
  status      String   @default("open") // open | planned | in_progress | shipped | declined
  voteCount   Int      @default(0) // denormalized for ordering; source of truth is votes
  isPublished Boolean  @default(false) // moderation gate — only published ideas are public
  authorEmail String? // captured for follow-up, never shown publicly
  createdAt   DateTime @default(now())

  votes IdeaVote[]

  @@index([isPublished, voteCount])
  @@index([createdAt])
}

// One vote per voter per idea. voterKey is "e:<email>" when an email is given,
// else "ip:<sha256(ip)>" — approximate dedup (good enough without auth), enforced
// by the unique constraint so a retry can never double-count.
model IdeaVote {
  id        String   @id @default(cuid())
  ideaId    String
  voterKey  String
  createdAt DateTime @default(now())

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([ideaId, voterKey])
  @@index([ideaId])
}
